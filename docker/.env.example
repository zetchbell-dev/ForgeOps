# =============================================================================
# ForgeOps — Local Development Environment Variables (TEMPLATE)
# =============================================================================
# LOCAL DEVELOPMENT ONLY.
#
# This is the tracked template. Copy it to a real .env before running the
# stack:
#
#   cp .env.example .env
#
# .env itself is git-ignored (see docker/.gitignore) — it is never
# committed, even though the values below are already non-secret,
# development-only placeholders. Keeping the real .env out of git is the
# habit that matters, not the sensitivity of today's specific values:
# it's what stops someone from later dropping real credentials into a
# file that git already expects to track.
#
# None of these values are used anywhere in production — production
# credentials live in AWS (RDS/ElastiCache + Secrets Manager) and are
# wired through Terraform, never through this file.
#
# If you change any credential in your local .env, update the
# corresponding value in your local Auth Service environment too (see
# README.md, "How to connect Auth Service").
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=forgeops_dev
POSTGRES_PASSWORD=forgeops_dev_password
POSTGRES_DB=forgeops_auth

# -----------------------------------------------------------------------------
# pgAdmin
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=dev@forgeops.local
PGADMIN_PASSWORD=forgeops_dev_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=forgeops_dev_redis_password

# -----------------------------------------------------------------------------
# Host port mappings
# -----------------------------------------------------------------------------
# Change any of these if the default port is already in use on your machine.
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050
REDIS_INSIGHT_PORT=5540
